# VoiceText Platform — Environment Variables
# Copy to .env and fill in values

# ─── API Server ───
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# ─── Database (PostgreSQL) ───
DATABASE_URL="postgresql://voicetext:voicetext_dev@localhost:5432/voicetext?schema=public"

# ─── Redis ───
REDIS_URL="redis://localhost:6379"

# ─── JWT Authentication ───
JWT_SECRET="change-me-to-a-random-secret-in-production"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# ─── OAuth (Optional) ───
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""
# OAUTH_CALLBACK_URL="http://localhost:3000/api/auth/callback"

# ─── CORS ───
CORS_ORIGIN="http://localhost:8080"

# ─── AI Providers (Optional) ───
# OPENAI_API_KEY=""
# ANTHROPIC_API_KEY=""
