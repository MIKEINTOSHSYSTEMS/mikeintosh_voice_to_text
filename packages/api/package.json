{
  "name": "@voicetext/api",
  "version": "2.0.0-alpha.1",
  "private": true,
  "description": "VoiceText API server",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:worker": "node dist/worker.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1089.0",
    "@aws-sdk/s3-request-presigner": "^3.1089.0",
    "@fastify/cors": "^10.0.1",
    "@fastify/env": "^5.0.1",
    "@fastify/jwt": "^9.0.1",
    "@fastify/multipart": "^9.4.0",
    "@fastify/swagger": "^9.8.1",
    "@prisma/client": "^6.9.0",
    "@scalar/fastify-api-reference": "^1.62.9",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.80.5",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "ioredis": "^5.11.1",
    "openai": "^4.104.0",
    "pino": "^10.3.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^22.12.0",
    "prisma": "^6.9.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
}
